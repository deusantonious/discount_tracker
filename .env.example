# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Monitor Bot Token (separate bot from @BotFather for analytics)
MONITOR_BOT_TOKEN=your_monitor_bot_token_here

# Your Telegram user ID (for admin access to monitor bot)
# Send /start to @userinfobot to get your ID
ADMIN_USER_ID=0

# Path to SQLite database file
DATABASE_PATH=price_tracker.db

# Hour (0-23) when daily price checks run
CHECK_HOUR=10
